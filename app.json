{
  "expo": {
    "name": "ontrek",
    "slug": "ontrek",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ontrek-icon.png",
    "splash": {
      "image": "./assets/images/ontrek-splash.png",
      "resizeMode": "cover"
    },
    "scheme": "ontrek",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "splash": {
        "image": "./assets/images/ontrek-splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ontrek-icon-dark.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kenali.ontrek"
    },
    "package": "com.kenali.ontrek",
    "extra": {
      "eas": {
        "projectId": "a1f59bb1-f518-4196-8af1-8b2c1510355e"
      }
    },
    "ios": {
      "bundleIdentifier": "com.kenali.ontrek"
    }
  },
  "ios": {
    "supportsTablet": true
  },
  "plugins": [
    "expo-sqlite",
    "expo-router",
    [
      "expo-splash-screen",
      {
        "backgroundColor": "#ffffff",
        "image": "./assets/images/ontrek-splash.png",
        "dark": {
          "image": "./assets/images/ontrek-splash-dark.png",
          "backgroundColor": "#000000"
        },
        "imageWidth": 200
      }
    ]
  ],
  "experiments": {
    "typedRoutes": true,
    "reactCompiler": true
  },
  "extra": {
    "router": {},
    "eas": {
      "projectId": "a1f59bb1-f518-4196-8af1-8b2c1510355e"
    }
  },
  "owner": "nfpurnama"
}
