{
  "expo": {
    "name": "ontrek",
    "slug": "ontrek",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ontrek-icon.png",
    "splash": {
      "image": "./assets/images/ontrek-splash.png",
      "resizeMode": "cover"
    },
    "scheme": "ontrek",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "splash": {
        "image": "./assets/images/ontrek-splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#1C2833"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      "expo-sqlite",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/ontrek-icon.png",
          "dark": {
            "image": "./assets/images/ontrek-icon.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
